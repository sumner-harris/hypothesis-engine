# Modified from the original work.
# LLM provider keys — set the one matching `[llm] provider` in your config.
#   provider = "anthropic"   → ANTHROPIC_API_KEY
#   provider = "openai"      → OPENAI_API_KEY
#   provider = "openrouter"  → OPENROUTER_API_KEY
#   provider = "gemini"      → GEMINI_API_KEY
#   provider = "groq"        → GROQ_API_KEY
#   provider = "together"    → TOGETHER_API_KEY
#   provider = "mistral"     → MISTRAL_API_KEY
#   provider = "ollama"      → (no key needed)
#   provider = "openai_compatible" -> OPENAI_API_KEY for remote endpoints; localhost is keyless
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
TOGETHER_API_KEY=
MISTRAL_API_KEY=
# OPENAI_BASE_URL=                  # optional; overrides [llm.openai] base_url

# Embeddings (local OpenAI-compatible endpoints are keyless; Voyage/OpenAI need keys)
# OPENAI_EMBEDDINGS_BASE_URL=       # optional; overrides [embeddings] base_url
VOYAGE_API_KEY=

# Web search (Tavily primary, Brave fallback)
TAVILY_API_KEY=
BRAVE_API_KEY=

# Optional: improves PubMed / OpenAlex rate limits
NCBI_API_KEY=
OPENALEX_API_KEY=
